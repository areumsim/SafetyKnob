{
  "system": {
    "name": "industrial_safety_assessment",
    "description": "Industrial image safety assessment using pre-trained vision models",
    "version": "1.0.0"
  },
  
  "models": [
    {
      "name": "siglip",
      "model_type": "siglip",
      "checkpoint": "google/siglip-so400m-patch14-384",
      "embedding_dim": 1152,
      "device": "cuda",
      "cache_dir": "./data/cache/siglip"
    },
    {
      "name": "clip",
      "model_type": "clip",
      "checkpoint": "openai/clip-vit-large-patch14",
      "embedding_dim": 768,
      "device": "cuda",
      "cache_dir": "./data/cache/clip"
    },
    {
      "name": "dinov2",
      "model_type": "dinov2",
      "checkpoint": "facebook/dinov2-large",
      "embedding_dim": 1024,
      "device": "cuda",
      "cache_dir": "./data/cache/dinov2"
    }
  ],
  
  "assessment_method": "ensemble",
  "ensemble_strategy": "weighted_vote",
  
  "safety": {
    "dimensions": {
      "fall_hazard": {
        "weight": 1.0,
        "description": "추락 위험"
      },
      "collision_risk": {
        "weight": 1.0,
        "description": "충돌 위험"
      },
      "equipment_hazard": {
        "weight": 1.0,
        "description": "장비 위험"
      },
      "environmental_risk": {
        "weight": 0.8,
        "description": "환경적 위험"
      },
      "protective_gear": {
        "weight": 0.8,
        "description": "보호구 착용"
      }
    },
    "safety_threshold": 0.5,
    "confidence_threshold": 0.7
  },
  
  "training": {
    "batch_size": 32,
    "learning_rate": 0.001,
    "epochs": 20,
    "optimizer": "adam",
    "scheduler": "cosine",
    "early_stopping_patience": 5,
    "weight_decay": 0.0001
  },
  
  "data": {
    "train_dir": "./data/train",
    "val_dir": "./data/val",
    "test_dir": "./data/test",
    "labels_file": "./data/labels.json",
    "augmentation": true,
    "num_workers": 4,
    "image_size": 224
  },
  
  "results_dir": "./results",
  "checkpoint_dir": "./checkpoints",
  "log_dir": "./logs",
  "save_embeddings": true,
  
  "api_host": "0.0.0.0",
  "api_port": 8000,
  "api_workers": 1
}